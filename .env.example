

# Node miljø
NODE_ENV=development

# Enforce login
# Sett til 'false' for lokal utvikling uten ID-porten
#
# false = lokalt/demo (bruker mockdata fra repo, ingen ID-porten eller API-kall)
#         Dette er anbefalt for lokal utvikling da det ikke krever autentisering
#
# true  = dev/prod (bruker Wonderwall med ekte ID-porten tokens og kaller reelle backend-APIer)
#         Krever at applikasjonen kjøres i NAIS med Wonderwall sidecar
ENFORCE_LOGIN=false

# Server konfigurasjon
HOST=0.0.0.0
PORT=4321

# Arena meldekort API
# Base URL inkluderer path til API-et (/meldekort/meldekort-api)
MELDEKORT_API_URL=https://meldekort-api-q2.intern.dev.nav.no/meldekort/meldekort-api
MELDEKORT_API_AUDIENCE=dev-gcp:meldekort:meldekort-api

# Tiltakspenger meldekort API
TILTAKSPENGER_API_URL=https://tiltakspenger-meldekort-api.intern.dev.nav.no
TILTAKSPENGER_API_AUDIENCE=dev-gcp:tpts:tiltakspenger-meldekort-api

# DP (dagpenger) meldekortregister API
DP_API_URL=https://dp-meldekortregister.intern.dev.nav.no
DP_API_AUDIENCE=dev-gcp:teamdagpenger:dp-meldekortregister

# AAP (arbeidsavklaringspenger) meldekort API
AAP_API_URL=https://meldekort-backend.intern.dev.nav.no
AAP_API_AUDIENCE=dev-gcp:aap:meldekort-backend
