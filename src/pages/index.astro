---
import '@navikt/ds-css';
import { Page, Heading, VStack, Alert, Link } from '@navikt/ds-react';
import { PortableText } from '@portabletext/react';
import { getDecoratorHTML } from '../lib/dekorator';
import { getLanguageFromCookie, translations, SUPPORTED_LANGUAGES } from '../lib/language';
import { sanityClient, getLandingssideQuery, sanityDataMissing } from '../lib/sanity';
import type { MeldekortLandingsside } from '../lib/sanity';
import type { AlleMeldekortData } from '../lib/types/meldekort';
import { skalViseLenker } from '../lib/utils/meldekort';
import { MeldekortLinkCards } from '../components/MeldekortLinkCards';
import { logger } from '../lib/utils/logger';
import { getToken } from '@navikt/oasis';
import { getMeldekortData } from '../lib/api/getMeldekortData';

const cookieHeader = Astro.request.headers.get('cookie');
const language = getLanguageFromCookie(cookieHeader);

const enforceLogin = (import.meta.env.ENFORCE_LOGIN ?? process.env.ENFORCE_LOGIN) !== 'false';

// Hent token fra request
const token = getToken(Astro.request.headers);

// Hent scenario fra query parameter (for mock mode)
const scenario = Astro.url.searchParams.get('scenario');

// Hent meldekortdata direkte (ingen intern HTTP-kall)
const meldekortResult = await getMeldekortData(token, scenario);

// Håndter feil og redirects
let alleMeldekort: AlleMeldekortData | null = null;

if (!meldekortResult.success) {
  logger.error('Failed to fetch meldekort data - showing error page to user', {
    status: meldekortResult.status,
    error: meldekortResult.error,
    details: meldekortResult.details,
  });
  Astro.response.status = meldekortResult.status;
} else {
  // Sjekk om vi skal redirecte
  if (meldekortResult.redirectUrl) {
    // Arena redirect - f.eks. til /felles-meldekort
    return Astro.redirect(meldekortResult.redirectUrl);
  }

  // Sjekk om kun 1 ytelse har aktive meldekort (redirect til den)
  const visning = skalViseLenker(meldekortResult.data);
  const alleMeldekortItems = [...visning.se, ...visning.sende, ...visning.fyllUt];
  const uniqueYtelser = [...new Set(alleMeldekortItems.map((item) => item.ytelse))];

  if (uniqueYtelser.length === 1) {
    const ytelse = uniqueYtelser[0];
    const ytelseUrl = meldekortResult.data[ytelse as keyof AlleMeldekortData]?.url;
    if (ytelseUrl) {
      return Astro.redirect(ytelseUrl);
    }
  }

  // Ellers, vis landingsside med data
  alleMeldekort = meldekortResult.data;
}

const apiFeil = !alleMeldekort;
const visning = alleMeldekort ? skalViseLenker(alleMeldekort) : { se: [], sende: [], fyllUt: [] };
const harKort = visning.se.length > 0 || visning.sende.length > 0 || visning.fyllUt.length > 0;

// Hent innhold fra Sanity
const query = getLandingssideQuery(language);
let content: MeldekortLandingsside | null = null;
try {
  content = await sanityClient.fetch<MeldekortLandingsside>(query);
} catch (error) {
  logger.error('Failed to fetch content from Sanity', { error });
}

// Sjekk om viktige felter mangler
const requiredFields: (keyof MeldekortLandingsside)[] = ['tittel', 'ytelser'];
const contentMissing = sanityDataMissing(
  content as unknown as Record<string, unknown>,
  requiredFields,
);

// Fallback til hardkodede oversettelser hvis Sanity-data ikke er tilgjengelig
const t = translations[language as keyof typeof translations] || translations.nb;

// Helper-variabler for å forenkle rendering-logikken
const hasValidContent = !contentMissing && !!content;
const tittel = hasValidContent && content ? content.tittel : t.tittel;
const hasEmptyState = hasValidContent && (content?.emptyStateTekst?.length ?? 0) > 0;
const hasBunntekst = hasValidContent && (content?.bunntekst?.length ?? 0) > 0;

const decorator = await getDecoratorHTML({
  env: import.meta.env.PROD ? 'prod' : 'dev',
  context: 'privatperson',
  simple: false,
  enforceLogin,
  level: 'Level3',
  redirectToApp: true,
  language,
  availableLanguages: SUPPORTED_LANGUAGES.map((locale: string) => ({
    locale,
    url: import.meta.env.BASE_URL,
    handleInApp: true,
  })),
});
---

<!doctype html>
<html lang={language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{tittel}</title>
    <Fragment set:html={decorator.DECORATOR_HEAD_ASSETS} />
    <script>
      import "../scripts/languageHandler";
    </script>
    <script is:inline define:vars={{ visning, harKort, apiFeil }}>
      // Gjør visning tilgjengelig for kort-tracking
      // VIKTIG: Dette må kjøre FØR analytics script for å unngå race condition
      window.__MELDEKORT_VISNING__ = { visning, harKort, apiFeil };
    </script>
    <script>
      import "../scripts/analytics";
    </script>
  </head>
  <body>
    <Fragment set:html={decorator.DECORATOR_HEADER} />
    <Page contentBlockPadding="end">
      <Page.Block as="main" width="2xl" gutters>
        <VStack gap="space-40">
          {
            !enforceLogin && (
              <Alert variant="info">
                <Heading size="xsmall" level="2" spacing>
                  Mock mode
                </Heading>
                Du kjører i mock mode.{" "}
                <Link href="/meldekort/dev/scenarios">
                  Se alle tilgjengelige scenarier
                </Link>{" "}
                eller bruk <code>?scenario=&lt;navn&gt;</code> i URL.
              </Alert>
            )
          }
          <Heading size="xlarge" level="1">{tittel}</Heading>
          {
            apiFeil ? (
              <div>
                <Heading size="medium" level="2" spacing>
                  {t.feilmelding.tittel}
                </Heading>
                <p>{t.feilmelding.beskrivelse}</p>
              </div>
            ) : harKort ? (
              hasValidContent &&
              content && (
                <VStack gap="space-24" maxWidth="525px">
                  <MeldekortLinkCards
                    client:load
                    visning={visning}
                    content={{
                      linkForASe: content.linkForASe,
                      linkForASende: content.linkForASende,
                      linkForAFylleUt: content.linkForAFylleUt,
                    }}
                    ytelser={content.ytelser}
                    language={language as (typeof SUPPORTED_LANGUAGES)[number]}
                  />
                </VStack>
              )
            ) : (
              hasEmptyState &&
              content && <PortableText value={content.emptyStateTekst} />
            )
          }
          {
            hasBunntekst && content && (
              <PortableText value={content.bunntekst} />
            )
          }
        </VStack>
      </Page.Block>
    </Page>
    <Fragment set:html={decorator.DECORATOR_FOOTER} />
    <Fragment set:html={decorator.DECORATOR_SCRIPTS} />
  </body>
</html>
